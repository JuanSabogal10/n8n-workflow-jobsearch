    {
      "parameters": {
        "jsCode": "// Datos del AI Agent (nodo actual)\nconst aiItems = $input.all();\n\n// Datos del nodo indeed (nodo anterior al AI)\nconst jobItems = $('Indeed').all();\n\nconst results = [];\n\nfor (let i = 0; i < aiItems.length; i++) {\n  try {\n    const job = jobItems[i]?.json ?? {};\n    const aiRaw = aiItems[i]?.json?.output ?? '';\n\n    // Limpia el output del AI (quita comillas externas si es string simple)\n    const cleaned = aiRaw\n      .replace(/^```json\\n?/i, '')\n      .replace(/```$/i, '')\n      .replace(/^\"([\\s\\S]*)\"$/, '$1') // quita comillas wrapper\n      .trim();\n\n    results.push({\n      json: {\n        // Datos del job\n        id:               job.id               ?? null,\n        company:          job.company          ?? null,\n        position:         job.positionName     ?? null,\n        job_type:         job.jobType?.[0]     ?? null,\n        location:         job.location         ?? null,\n        salary:           job.salary           ?? null,\n        url:              job.url              ?? null,\n        url_apply:        job.externalApplyLink ?? null,\n        url_company:      job.companyInfo?.url ?? null,\n        posted_at:        job.postedAt         ?? null,\n        rating:           job.rating           ?? null,\n        is_expired:       job.isExpired        ?? false,\n        company_logo:     job.companyInfo?.companyLogo ?? null,\n        company_size_min: job.companyInfo?.companySize?.min ?? null,\n        company_size_max: job.companyInfo?.companySize?.max ?? null,\n\n        // Output del AI (texto plano — carta de motivación)\n        carta_motivacion: cleaned,\n\n        // Meta\n        _parsed_at: new Date().toISOString(),\n      }\n    });\n\n  } catch (e) {\n    results.push({\n      json: {\n        _error: true,\n        _error_message: e.message,\n        _index: i,\n        _parsed_at: new Date().toISOString(),\n      }\n    });\n  }\n}\n\nreturn results;"
      },
